" class="-ms-0.5 icon"><use href="/cdn/assets/sprites-core-f8sla627.svg#6ef7a4" fill="currentColor"></use></svg>Run</div></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="w-full overflow-x-hidden overflow-y-auto" style="transform: none; max-height: 433px;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼe">prob</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">model</span><span class="ͼ8">.</span><span>predict_proba(</span><span class="ͼe">input_scaled</span><span>)[</span><span class="ͼb">0</span><span>][</span><span class="ͼb">1</span><span>]</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>write(</span><span class="ͼc">f"Risk Probability: </span><span>{</span><span class="ͼe">prob</span><span>:</span><span class="ͼ8">.2f</span><span>}</span><span class="ͼc">"</span><span>)</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
