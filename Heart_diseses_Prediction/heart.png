<h3 data-start="362" data-end="389" data-section-id="w360al"><span role="text">1. <strong data-start="369" data-end="389">train_test_split</strong></span></h3>
<ul data-start="390" data-end="491">
<li data-start="390" data-end="491" data-section-id="19u5ny7">
