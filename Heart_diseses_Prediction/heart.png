ansform: none; max-height: 433px;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span>python </span><span class="ͼf">-m</span><span> venv venv</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
<h3 data-section-id="6xuuv9" data-start="466" data-end="479">Activate:</h3>
<ul data-start="480" data-end="490">
<li data-section-id="vlpu99" data-start="480" data-end="490">
<p data-start="482" data-end="490">Windows:</p>
