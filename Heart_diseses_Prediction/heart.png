c(var(--spacing)*16))] px-(--thread-content-margin)"><div class="[--thread-content-max-width:40rem] @w-lg/main:[--thread-content-max-width:48rem] mx-auto max-w-(--thread-content-max-width) flex-1 group/turn-messages focus-visible:outline-hidden relative flex w-full min-w-0 flex-col agent-turn"><div class="flex max-w-full flex-col gap-4 grow"><div data-message-author-role="assistant" data-message-id="4344c6a3-d1e5-44b0-a5af-455dce84f55a" dir="auto" data-message-model-slug="gpt-5-3" class="min-h-8 text-message relative flex w-full flex-col items-end gap-2 text-start break-words whitespace-normal outline-none keyboard-focused:focus-ring [.text-message+&amp;]:mt-1"><div class="flex w-full flex-col gap-1 empty:hidden"><div class="markdown prose dark:prose-invert w-full wrap-break-word light markdown-new-styling"><p data-start="0" data-end="150">Here’s a <strong data-start="9" data-end="58">🔥 professional + attractive GitHub README.md</strong> for your Heart Disease Prediction project. You can copy-paste this directly into your repo.</p>
<hr data-start="152" data-end="155">
<div class="group relative clear-both my-4 w-full overflow-visible"><div id="writing-block-4344c6a3-d1e5-44b0-a5af-455dce84f55a" class="relative w-full overflow-clip rounded-[24px] bg-token-bg-primary dark:bg-[#2a2a2a] shadow-[0px_4px_80px_rgba(0,0,0,0.02)]" data-writing-block="true" data-testid="writing-block-container"><div class="z-1 md:sticky top-(--sticky-padding-top)" data-testid="writing-block-header-sticky-container"><div class="bg-token-bg-primary flex w-full items-center justify-between gap-3 font-sans dark:bg-[#2a2a2a] py-2.5" data-testid="writing-block-header-surface" style="padding-left: calc(5 * var(--spacing)); padding-right: calc(1 * var(--spacing));"><div class="flex grow gap-3 items-center"><div class="text-token-text-tertiary flex max-w-[75%] min-w-0 grow cursor-default items-center self-center text-sm font-medium"><div class="truncate">Writing</div></div></div><div class="flex shrink-0 items-center"><div class="flex items-center"><div class="flex items-center"><button class="gap-1 select-none text-sm font-medium text-token-text-primary hover:bg-token-bg-tertiary flex size-9 items-center justify-center rounded-full p-1.5 transition-colors disabled:opacity-40 disabled:hover:bg-transparent" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-f8sla627.svg#ce3544" fill="currentColor"></use></svg></button></div><div class="flex items-center"></div><div class="flex items-center"></div></div></div></div></div><div class="writing-block-editor markdown-new-styling relative flow-root pt-(--writing-block-editor-pt) pe-(--writing-block-editor-pr) pb-(--writing-block-editor-pb) ps-(--writing-block-editor-pl)" style="--writing-block-editor-pt: 0px; --writing-block-editor-pr: calc(5 * var(--spacing)); --writing-block-editor-pb: calc(4 * var(--spacing)); --writing-block-editor-pl: calc(5 * var(--spacing));"><div class="ProseMirror markdown prose dark:prose-invert w-full min-h-6 break-words focus:outline-none" contenteditable="true" aria-disabled="false" dir="auto" translate="no"><h1><span>❤️ Heart Stroke Disease Prediction</span></h1><p><span>🚀 </span><strong><span>An end-to-end Machine Learning web application</span></strong><span> that predicts the risk of heart stroke disease based on user health data.</span><br><span>Built with </span><strong><span>Streamlit, Python, and Scikit-learn</span></strong><span> with a modern UI design.</span></p><div contenteditable="false"><hr></div><h2><span>📌 Project Overview</span></h2><p><span>This project uses a </span><strong><span>K-Nearest Neighbors (KNN)</span></strong><span> model to analyze health parameters and predict whether a person is at </span><strong><span>high risk or low risk of heart stroke</span></strong><span>.</span></p><p><span>The application provides:</span></p><ul data-spread="false"><li><p><span>✅ Real-time prediction</span></p></li><li><p><span>✅ Clean and interactive UI</span></p></li><li><p><span>✅ Data preprocessing (encoding + scaling)</span></p></li><li><p><span>✅ Deployment-ready ML pipeline</span></p></li></ul><div contenteditable="false"><hr></div><h2><span>🎯 Features</span></h2><p><span>✨ User-friendly web interface (Streamlit)</span><br><span>✨ Tailwind-inspired modern UI</span><br><span>✨ Real-time prediction with probability score</span><br><span>✨ Data preprocessing (One-hot encoding + StandardScaler)</span><br><span>✨ Trained ML model integration using Joblib</span></p><div contenteditable="false"><hr></div><h2><span>🛠️ Tech Stack</span></h2><ul data-spread="false"><li><p><strong><span>Language:</span></strong><span> Python 🐍</span></p></li><li><p><strong><span>Libraries:</span></strong><span> Pandas, NumPy, Scikit-learn</span></p></li><li><p><strong><span>Visualization/UI:</span></strong><span> Streamlit</span></p></li><li><p><strong><span>Model:</span></strong><span> KNN Classifier</span></p></li><li><p><strong><span>Deployment:</span></strong><span> Streamlit Cloud / Local</span></p></li></ul><div contenteditable="false"><hr></div><h2><span>📂 Project Structure</span></h2><pre dir="ltr"><code dir="ltr"><span>📁 Heart-Stroke-Prediction
│── app.py                 # Streamlit app
│── KNN_heart_model.pkl    # Trained ML model
│── scaler.pkl            # Scaler object
│── heart_columns.pkl     # Encoded column structure
│── requirements.txt      # Dependencies
│── README.md             # Project documentation</span></code></pre><div contenteditable="false"><hr></div><h2><span>⚙️ How It Works</span></h2><p><span>1️⃣ User enters health details (age, BMI, glucose, etc.)</span><br><span>2️⃣ Data is converted into a structured format</span><br><span>3️⃣ One-hot encoding is applied</span><br><span>4️⃣ Data is scaled using StandardScaler</span><br><span>5️⃣ Model predicts risk using KNN algorithm</span></p><div contenteditable="false"><hr></div><h2><span>📊 Model Performance</span></h2><ul data-spread="false"><li><p><span>✔️ Accuracy: ~85% (example — update if needed)</span></p></li><li><p><span>✔️ Evaluation Metrics:</span></p><ul data-spread="false"><li><p><span>Accuracy Score</span></p></li><li><p><span>Confusion Matrix</span></p></li><li><p><span>Classification Report</span></p></li></ul></li></ul><div contenteditable="false"><hr></div><h2><span>🚀 Run Locally</span></h2><pre dir="ltr"><code dir="ltr"><span># Clone the repository
git clone https://github.com/your-username/heart-stroke-prediction.git

# Navigate to project
cd heart-stroke-prediction

# Install dependencies
pip install -r requirements.txt

# Run the app
streamlit run app.py</span></code></pre><div contenteditable="false"><hr></div><h2><span>🌐 Live Demo</span></h2><p><span>👉 </span><em><span>Add your deployed link here</span></em></p><div contenteditable="false"><hr></div><h2><span>📸 Screenshots</span></h2><p><em><span>Add screenshots of your app UI here</span></em></p><div contenteditable="false"><hr></div><h2><span>💡 Future Improvements</span></h2><ul data-spread="false"><li><p><span>🔹 Add more ML models (Logistic Regression, Random Forest)</span></p></li><li><p><span>🔹 Improve accuracy with feature engineering</span></p></li><li><p><span>🔹 Deploy on cloud (AWS / Render)</span></p></li><li><p><span>🔹 Add authentication system</span></p></li></ul><div contenteditable="false"><hr></div><h2><span>👨‍💻 Author</span></h2><p><strong><span>Divesh Kumar</span></strong><br><span>📧 </span><a href="mailto:diveshkumar4464@gmail.com"><span>diveshkumar4464@gmail.com</span></a><br><span>🔗 LinkedIn: </span><a href="https://linkedin.com/in/divesh-kumar-109b6b263"><span>https://linkedin.com/in/divesh-kumar-109b6b263</span></a></p><div contenteditable="false"><hr></div><h2><span>⭐ Support</span></h2><p><span>If you like this project, give it a ⭐ on GitHub!</span></p></div></div><div aria-hidden="true" class="pointer-events-none absolute inset-0 z-2 rounded-[24px] shadow-[inset_0px_0px_0px_1px_rgba(0,0,0,0.07)]"></div></div></div>
