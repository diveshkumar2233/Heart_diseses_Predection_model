n><br><span class="ͼc">    .main {</span><br><span class="ͼc">        background-color: #f5f7fa;</span><br><span class="ͼc">    }</span><br><span class="ͼc">    .stButton&gt;button {</span><br><span class="ͼc">        background-color: #ff4b4b;</span><br><span class="ͼc">        color: white;</span><br><span class="ͼc">        border-radius: 10px;</span><br><span class="ͼc">        height: 3em;</span><br><span class="ͼc">        width: 100%;</span><br><span class="ͼc">        font-size: 18px;</span><br><span class="ͼc">    }</span><br><span class="ͼc">    .stButton&gt;button:hover {</span><br><span class="ͼc">        background-color: #ff1f1f;</span><br><span class="ͼc">    }</span><br><span class="ͼc">    &lt;/style&gt;</span><br><span class="ͼc">"""</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span><br><br><span class="ͼ6"># Load model</span><br><span class="ͼe">model</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">joblib</span><span class="ͼ8">.</span><span>load(</span><span class="ͼc">'KNN_heart_model.pkl'</span><span>)</span><br><span class="ͼe">scaler</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">joblib</span><span class="ͼ8">.</span><span>load(</span><span class="ͼc">'scaler.pkl'</span><span>)</span><br><span class="ͼe">expected_columns</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">joblib</span><span class="ͼ8">.</span><span>load(</span><span class="ͼc">'heart_columns.pkl'</span><span>)</span><br><br><span class="ͼ6"># Title Section</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">"&lt;h1 style='text-align:center; color:#ff4b4b;'&gt;❤️ Heart Stroke Prediction&lt;/h1&gt;"</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">"&lt;p style='text-align:center;'&gt;AI-based health risk prediction system&lt;/p&gt;"</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span><br><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>write(</span><span class="ͼc">"---"</span><span>)</span><br><br><span class="ͼ6"># Layout in columns</span><br><span class="ͼe">col1</span><span>, </span><span class="ͼe">col2</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>columns(</span><span class="ͼb">2</span><span>)</span><br><br><span class="ͼ8">with</span><span> </span><span class="ͼe">col1</span><span>:</span><br><span>    </span><span class="ͼe">age</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>number_input(</span><span class="ͼc">"Age"</span><span>, </span><span class="ͼb">1</span><span>, </span><span class="ͼb">120</span><span>, </span><span class="ͼb">25</span><span>)</span><br><span>    </span><span class="ͼe">gender</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>selectbox(</span><span class="ͼc">"Gender"</span><span>, [</span><span class="ͼc">"Male"</span><span>, </span><span class="ͼc">"Female"</span><span>])</span><br><span>    </span><span class="ͼe">hypertension</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>selectbox(</span><span class="ͼc">"Hypertension"</span><span>, [</span><span class="ͼb">0</span><span>, </span><span class="ͼb">1</span><span>])</span><br><span>    </span><span class="ͼe">heart_disease</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>selectbox(</span><span class="ͼc">"Heart Disease History"</span><span>, [</span><span class="ͼb">0</span><span>, </span><span class="ͼb">1</span><span>])</span><br><br><span class="ͼ8">with</span><span> </span><span class="ͼe">col2</span><span>:</span><br><span>    </span><span class="ͼe">avg_glucose_level</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>number_input(</span><span class="ͼc">"Avg Glucose Level"</span><span>, </span><span class="ͼb">50.0</span><span>, </span><span class="ͼb">300.0</span><span>, </span><span class="ͼb">100.0</span><span>)</span><br><span>    </span><span class="ͼe">bmi</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>number_input(</span><span class="ͼc">"BMI"</span><span>, </span><span class="ͼb">10.0</span><span>, </span><span class="ͼb">50.0</span><span>, </span><span class="ͼb">22.0</span><span>)</span><br><span>    </span><span class="ͼe">smoking_status</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>selectbox(</span><span class="ͼc">"Smoking Status"</span><span>, [</span><span class="ͼc">"never smoked"</span><span>, </span><span class="ͼc">"formerly smoked"</span><span>, </span><span class="ͼc">"smokes"</span><span>])</span><br><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>write(</span><span class="ͼc">"---"</span><span>)</span><br><br><span class="ͼ6"># Convert to dataframe</span><br><span class="ͼe">input_data</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">pd</span><span class="ͼ8">.</span><span>DataFrame({</span><br><span>    </span><span class="ͼc">'age'</span><span>: [</span><span class="ͼe">age</span><span>],</span><br><span>    </span><span class="ͼc">'hypertension'</span><span>: [</span><span class="ͼe">hypertension</span><span>],</span><br><span>    </span><span class="ͼc">'heart_disease'</span><span>: [</span><span class="ͼe">heart_disease</span><span>],</span><br><span>    </span><span class="ͼc">'avg_glucose_level'</span><span>: [</span><span class="ͼe">avg_glucose_level</span><span>],</span><br><span>    </span><span class="ͼc">'bmi'</span><span>: [</span><span class="ͼe">bmi</span><span>],</span><br><span>    </span><span class="ͼc">'gender'</span><span>: [</span><span class="ͼe">gender</span><span>],</span><br><span>    </span><span class="ͼc">'smoking_status'</span><span>: [</span><span class="ͼe">smoking_status</span><span>]</span><br><span>})</span><br><br><span class="ͼ6"># Encoding</span><br><span class="ͼe">input_data</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">pd</span><span class="ͼ8">.</span><span>get_dummies(</span><span class="ͼe">input_data</span><span>)</span><br><span class="ͼe">input_data</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">input_data</span><span class="ͼ8">.</span><span>reindex(</span><span class="ͼe">columns</span><span class="ͼ8">=</span><span class="ͼe">expected_columns</span><span>, </span><span class="ͼe">fill_value</span><span class="ͼ8">=</span><span class="ͼb">0</span><span>)</span><br><br><span class="ͼ6"># Scaling</span><br><span class="ͼe">input_scaled</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">scaler</span><span class="ͼ8">.</span><span>transform(</span><span class="ͼe">input_data</span><span>)</span><br><br><span class="ͼ6"># Prediction Button</span><br><span class="ͼ8">if</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>button(</span><span class="ͼc">"🔍 Predict Risk"</span><span>):</span><br><span>    </span><span class="ͼe">prediction</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">model</span><span class="ͼ8">.</span><span>predict(</span><span class="ͼe">input_scaled</span><span>)</span><br><br><span>    </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>write(</span><span class="ͼc">"---"</span><span>)</span><br><br><span>    </span><span class="ͼ8">if</span><span> </span><span class="ͼe">prediction</span><span>[</span><span class="ͼb">0</span><span>] </span><span class="ͼ8">==</span><span> </span><span class="ͼb">1</span><span>:</span><br><span>        </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>error(</span><span class="ͼc">"⚠️ High Risk of Heart Stroke"</span><span>)</span><br><span>        </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">"### 🚨 Please consult a doctor immediately."</span><span>)</span><br><span>    </span><span class="ͼ8">else</span><span>:</span><br><span>        </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>success(</span><span class="ͼc">"✅ Low Risk of Heart Stroke"</span><span>)</span><br><span>        </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">"### 👍 Keep maintaining a healthy lifestyle!"</span><span>)</span><br><br><span class="ͼ6"># Footer</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>write(</span><span class="ͼc">"---"</span><span>)</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">"&lt;p style='text-align:center;'&gt;Developed by Divesh Kumar&lt;/p&gt;"</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
