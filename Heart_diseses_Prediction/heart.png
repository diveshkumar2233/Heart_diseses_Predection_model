<h1 data-section-id="1nqoygg" data-start="318" data-end="360">✅ 🔥 Streamlit + Tailwind Styled Version</h1>
<pre class="overflow-visible! px-0!" data-start="362" data-end="3366"><div class="relative w-full mt-4 mb-1"><div class=""><div class="relative"><div class="h-full min-h-0 min-w-0"><div class="h-full min-h-0 min-w-0" style="width: 100%; transform: none;"><div class="border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl"><div class="h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback"><div class="sticky z-2 select-none top-(--sticky-padding-top)"><div class="flex w-full items-center justify-between py-1.5 ps-4 pe-1.5 font-sans md:ps-5 bg-token-bg-elevated-secondary"><div class="flex max-w-[75%] min-w-0 cursor-default items-center text-sm font-medium justify-self-start text-token-text-primary"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-sm me-2.5 shrink-0"><use href="/cdn/assets/sprites-core-f8sla627.svg#e45ab3" fill="currentColor"></use></svg>Python</div><div class="flex flex-row items-center gap-0.5 justify-self-end"><button class="flex gap-1 items-center select-none py-2 text-sm font-medium hover:bg-black/5 dark:hover:bg-white/10 size-9 rounded-full px-2" aria-label="Copy" data-state="closed"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-hidden="true" class="icon-md"><use href="/cdn/assets/sprites-core-f8sla627.svg#ce3544" fill="currentColor"></use></svg></button><button class="btn relative group-focus-within/dialog:focus-visible:[outline-width:1.5px] group-focus-within/dialog:focus-visible:[outline-offset:2.5px] group-focus-within/dialog:focus-visible:[outline-style:solid] group-focus-within/dialog:focus-visible:[outline-color:var(--text-primary)] btn-ghost border-token-border-default ms-2 border font-sans" aria-label="Run code" type="button"><div class="flex w-full items-center justify-center gap-1.5"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" aria-label="" class="-ms-0.5 icon"><use href="/cdn/assets/sprites-core-f8sla627.svg#6ef7a4" fill="currentColor"></use></svg>Run</div></button></div></div></div><div class="pointer-events-none absolute inset-x-4 top-12 bottom-4"><div class="pointer-events-none sticky z-40 shrink-0 z-1!" style="top: calc(calc(var(--sticky-padding-top) + 48px) - 1px * 3); margin-bottom: calc(-4px); height: calc(4px); mask-image: linear-gradient(transparent 25%, white 75%);"><div class="sticky bg-token-border-light" style="top: calc(var(--sticky-padding-top) + 48px); height: 1px;"></div></div></div><div class="relative"><div class="w-full overflow-x-hidden overflow-y-auto" style="transform: none; max-height: 433px;"><div class="relative z-0 flex max-w-full"><div id="code-block-viewer" dir="ltr" class="q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light flex h-full w-full flex-col items-stretch ͼ5 ͼj"><div class="cm-scroller"><div class="cm-content q9tKkq_readonly"><span class="ͼ8">import</span><span> </span><span class="ͼe">streamlit</span><span> </span><span class="ͼ8">as</span><span> </span><span class="ͼe">st</span><br><span class="ͼ8">import</span><span> </span><span class="ͼe">pandas</span><span> </span><span class="ͼ8">as</span><span> </span><span class="ͼe">pd</span><br><span class="ͼ8">import</span><span> </span><span class="ͼe">joblib</span><br><br><span class="ͼ6"># Page config</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>set_page_config(</span><span class="ͼe">page_title</span><span class="ͼ8">=</span><span class="ͼc">"Heart Stroke Prediction"</span><span>, </span><span class="ͼe">page_icon</span><span class="ͼ8">=</span><span class="ͼc">"❤️"</span><span>, </span><span class="ͼe">layout</span><span class="ͼ8">=</span><span class="ͼc">"centered"</span><span>)</span><br><br><span class="ͼ6"># Tailwind CDN</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">"""</span><br><span class="ͼc">&lt;link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet"&gt;</span><br><span class="ͼc">"""</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span><br><br><span class="ͼ6"># Load model</span><br><span class="ͼe">model</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">joblib</span><span class="ͼ8">.</span><span>load(</span><span class="ͼc">'KNN_heart_model.pkl'</span><span>)</span><br><span class="ͼe">scaler</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">joblib</span><span class="ͼ8">.</span><span>load(</span><span class="ͼc">'scaler.pkl'</span><span>)</span><br><span class="ͼe">expected_columns</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">joblib</span><span class="ͼ8">.</span><span>load(</span><span class="ͼc">'heart_columns.pkl'</span><span>)</span><br><br><span class="ͼ6"># Header Card</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">"""</span><br><span class="ͼc">&lt;div class="bg-red-500 p-6 rounded-2xl shadow-lg text-white text-center"&gt;</span><br><span class="ͼc">    &lt;h1 class="text-3xl font-bold"&gt;❤️ Heart Stroke Prediction&lt;/h1&gt;</span><br><span class="ͼc">    &lt;p class="mt-2"&gt;AI-powered health risk detection system&lt;/p&gt;</span><br><span class="ͼc">&lt;/div&gt;</span><br><span class="ͼc">&lt;br&gt;</span><br><span class="ͼc">"""</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span><br><br><span class="ͼ6"># Input Section Card</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">'&lt;div class="bg-white p-6 rounded-2xl shadow-md"&gt;'</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span><br><br><span class="ͼe">col1</span><span>, </span><span class="ͼe">col2</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>columns(</span><span class="ͼb">2</span><span>)</span><br><br><span class="ͼ8">with</span><span> </span><span class="ͼe">col1</span><span>:</span><br><span>    </span><span class="ͼe">age</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>number_input(</span><span class="ͼc">"Age"</span><span>, </span><span class="ͼb">1</span><span>, </span><span class="ͼb">120</span><span>, </span><span class="ͼb">25</span><span>)</span><br><span>    </span><span class="ͼe">gender</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>selectbox(</span><span class="ͼc">"Gender"</span><span>, [</span><span class="ͼc">"Male"</span><span>, </span><span class="ͼc">"Female"</span><span>])</span><br><span>    </span><span class="ͼe">hypertension</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>selectbox(</span><span class="ͼc">"Hypertension"</span><span>, [</span><span class="ͼb">0</span><span>, </span><span class="ͼb">1</span><span>])</span><br><span>    </span><span class="ͼe">heart_disease</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>selectbox(</span><span class="ͼc">"Heart Disease History"</span><span>, [</span><span class="ͼb">0</span><span>, </span><span class="ͼb">1</span><span>])</span><br><br><span class="ͼ8">with</span><span> </span><span class="ͼe">col2</span><span>:</span><br><span>    </span><span class="ͼe">avg_glucose_level</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>number_input(</span><span class="ͼc">"Avg Glucose Level"</span><span>, </span><span class="ͼb">50.0</span><span>, </span><span class="ͼb">300.0</span><span>, </span><span class="ͼb">100.0</span><span>)</span><br><span>    </span><span class="ͼe">bmi</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>number_input(</span><span class="ͼc">"BMI"</span><span>, </span><span class="ͼb">10.0</span><span>, </span><span class="ͼb">50.0</span><span>, </span><span class="ͼb">22.0</span><span>)</span><br><span>    </span><span class="ͼe">smoking_status</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>selectbox(</span><span class="ͼc">"Smoking Status"</span><span>, [</span><span class="ͼc">"never smoked"</span><span>, </span><span class="ͼc">"formerly smoked"</span><span>, </span><span class="ͼc">"smokes"</span><span>])</span><br><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">'&lt;/div&gt;&lt;br&gt;'</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span><br><br><span class="ͼ6"># Convert input</span><br><span class="ͼe">input_data</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">pd</span><span class="ͼ8">.</span><span>DataFrame({</span><br><span>    </span><span class="ͼc">'age'</span><span>: [</span><span class="ͼe">age</span><span>],</span><br><span>    </span><span class="ͼc">'hypertension'</span><span>: [</span><span class="ͼe">hypertension</span><span>],</span><br><span>    </span><span class="ͼc">'heart_disease'</span><span>: [</span><span class="ͼe">heart_disease</span><span>],</span><br><span>    </span><span class="ͼc">'avg_glucose_level'</span><span>: [</span><span class="ͼe">avg_glucose_level</span><span>],</span><br><span>    </span><span class="ͼc">'bmi'</span><span>: [</span><span class="ͼe">bmi</span><span>],</span><br><span>    </span><span class="ͼc">'gender'</span><span>: [</span><span class="ͼe">gender</span><span>],</span><br><span>    </span><span class="ͼc">'smoking_status'</span><span>: [</span><span class="ͼe">smoking_status</span><span>]</span><br><span>})</span><br><br><span class="ͼ6"># Encoding</span><br><span class="ͼe">input_data</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">pd</span><span class="ͼ8">.</span><span>get_dummies(</span><span class="ͼe">input_data</span><span>)</span><br><span class="ͼe">input_data</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">input_data</span><span class="ͼ8">.</span><span>reindex(</span><span class="ͼe">columns</span><span class="ͼ8">=</span><span class="ͼe">expected_columns</span><span>, </span><span class="ͼe">fill_value</span><span class="ͼ8">=</span><span class="ͼb">0</span><span>)</span><br><br><span class="ͼ6"># Scaling</span><br><span class="ͼe">input_scaled</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">scaler</span><span class="ͼ8">.</span><span>transform(</span><span class="ͼe">input_data</span><span>)</span><br><br><span class="ͼ6"># Button</span><br><span class="ͼ8">if</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>button(</span><span class="ͼc">"🔍 Predict Risk"</span><span>):</span><br><span>    </span><span class="ͼ8">with</span><span> </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>spinner(</span><span class="ͼc">"Analyzing..."</span><span>):</span><br><span>        </span><span class="ͼe">prediction</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">model</span><span class="ͼ8">.</span><span>predict(</span><span class="ͼe">input_scaled</span><span>)</span><br><span>        </span><span class="ͼe">prob</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">model</span><span class="ͼ8">.</span><span>predict_proba(</span><span class="ͼe">input_scaled</span><span>)[</span><span class="ͼb">0</span><span>][</span><span class="ͼb">1</span><span>]</span><br><br><span>    </span><span class="ͼ6"># Result Card</span><br><span>    </span><span class="ͼ8">if</span><span> </span><span class="ͼe">prediction</span><span>[</span><span class="ͼb">0</span><span>] </span><span class="ͼ8">==</span><span> </span><span class="ͼb">1</span><span>:</span><br><span>        </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">f"""</span><br><span class="ͼc">        &lt;div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-xl shadow"&gt;</span><br><span class="ͼc">            &lt;h2 class="text-xl font-bold"&gt;⚠️ High Risk of Heart Stroke&lt;/h2&gt;</span><br><span class="ͼc">            &lt;p class="mt-2"&gt;Risk Probability: </span><span>{</span><span class="ͼe">prob</span><span>:</span><span class="ͼ8">.2f</span><span>}</span><span class="ͼc">&lt;/p&gt;</span><br><span class="ͼc">            &lt;p class="mt-2"&gt;Please consult a doctor immediately.&lt;/p&gt;</span><br><span class="ͼc">        &lt;/div&gt;</span><br><span class="ͼc">        """</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span><br><span>    </span><span class="ͼ8">else</span><span>:</span><br><span>        </span><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">f"""</span><br><span class="ͼc">        &lt;div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 rounded-xl shadow"&gt;</span><br><span class="ͼc">            &lt;h2 class="text-xl font-bold"&gt;✅ Low Risk of Heart Stroke&lt;/h2&gt;</span><br><span class="ͼc">            &lt;p class="mt-2"&gt;Risk Probability: </span><span>{</span><span class="ͼe">prob</span><span>:</span><span class="ͼ8">.2f</span><span>}</span><span class="ͼc">&lt;/p&gt;</span><br><span class="ͼc">            &lt;p class="mt-2"&gt;Maintain a healthy lifestyle.&lt;/p&gt;</span><br><span class="ͼc">        &lt;/div&gt;</span><br><span class="ͼc">        """</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span><br><br><span class="ͼ6"># Footer</span><br><span class="ͼe">st</span><span class="ͼ8">.</span><span>markdown(</span><span class="ͼc">"""</span><br><span class="ͼc">&lt;br&gt;</span><br><span class="ͼc">&lt;div class="text-center text-gray-500"&gt;</span><br><span class="ͼc">    Developed by Divesh Kumar 🚀</span><br><span class="ͼc">&lt;/div&gt;</span><br><span class="ͼc">"""</span><span>, </span><span class="ͼe">unsafe_allow_html</span><span class="ͼ8">=</span><span class="ͼb">True</span><span>)</span></div></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
